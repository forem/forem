#!/usr/bin/env python3
"""
Export a Shelley conversation from its SQLite database to JSONL format
or upload it directly to a Forem instance via an ingest URL.

Usage:
  shelley-export <conversation_id_or_slug> [--db PATH]
  shelley-export <conversation_id_or_slug> --upload <ingest_url>

The default database path is ~/.config/shelley/shelley.db

Without --upload, output goes to stdout:
  shelley-export my-session > session.jsonl

With --upload, posts directly to Forem:
  shelley-export my-session --upload https://dev.to/agent_sessions/ingest/TOKEN
"""

import json
import os
import sqlite3
import sys
import argparse
import urllib.request
import urllib.error


def get_db_path():
    return os.path.expanduser("~/.config/shelley/shelley.db")


def find_conversation(db, identifier):
    """Find a conversation by ID or slug."""
    cursor = db.execute(
        "SELECT conversation_id, slug, model, cwd, created_at, updated_at "
        "FROM conversations WHERE conversation_id = ? OR slug = ?",
        (identifier, identifier),
    )
    row = cursor.fetchone()
    if not row:
        return None
    return {
        "conversation_id": row[0],
        "slug": row[1],
        "model": row[2],
        "cwd": row[3],
        "created_at": row[4],
        "updated_at": row[5],
    }


def get_messages(db, conversation_id):
    """Get all messages for a conversation, ordered by sequence."""
    cursor = db.execute(
        "SELECT sequence_id, type, llm_data, created_at "
        "FROM messages WHERE conversation_id = ? "
        "ORDER BY sequence_id",
        (conversation_id,),
    )
    return cursor.fetchall()


def role_from_type(msg_type):
    """Map message type to role."""
    mapping = {"system": "system", "user": "user", "agent": "assistant"}
    return mapping.get(msg_type)


def truncate_str(s, max_len):
    if s is None:
        return s
    if len(s) <= max_len:
        return s
    return s[:max_len] + "..."


def summarize_tool_input(name, tool_input):
    """Summarize tool input to a short string."""
    if not tool_input or not isinstance(tool_input, dict):
        return None

    if name == "bash":
        return tool_input.get("command")
    elif name == "patch":
        return tool_input.get("path")
    elif name == "keyword_search":
        q = tool_input.get("query")
        return truncate_str(q, 100) if q else None
    elif name == "change_dir":
        return tool_input.get("path")
    elif name == "browser":
        return tool_input.get("url") or tool_input.get("action")
    elif name in ("browser_emulate", "browser_network", "browser_accessibility", "browser_profile"):
        return tool_input.get("action")
    elif name == "output_iframe":
        return tool_input.get("path") or tool_input.get("title")
    elif name == "subagent":
        slug = tool_input.get("slug", "")
        prompt = truncate_str(tool_input.get("prompt", ""), 80)
        return f"{slug}: {prompt}" if slug else prompt
    elif name == "llm_one_shot":
        return tool_input.get("prompt_file")
    elif name == "read_image":
        return tool_input.get("path")
    else:
        return truncate_str(json.dumps(tool_input), 200)


def extract_tool_result_text(block):
    """Extract text from a tool result block."""
    results = block.get("ToolResult")
    if not isinstance(results, list):
        return ""
    texts = [r["Text"] for r in results if r.get("Type") == 2 and r.get("Text")]
    return "\n".join(texts)


def build_normalized(db, conv):
    """Build normalized agent session data from a conversation."""
    messages_raw = get_messages(db, conv["conversation_id"])

    # First pass: build tool results map
    tool_results_map = {}
    parsed_records = []
    for seq_id, msg_type, llm_data_json, created_at in messages_raw:
        role = role_from_type(msg_type)
        if role is None:
            continue
        try:
            llm_data = json.loads(llm_data_json) if llm_data_json else {}
        except json.JSONDecodeError:
            continue
        content = llm_data.get("Content", [])
        if not content:
            continue

        parsed_records.append((role, content, created_at))

        if role == "user":
            for block in content:
                if block.get("Type") == 6 and block.get("ToolUseID"):
                    tool_results_map[block["ToolUseID"]] = extract_tool_result_text(block)

    # Second pass: build normalized messages
    normalized_messages = []
    for role, content, timestamp in parsed_records:
        if role == "system":
            continue

        if role == "user":
            blocks = []
            for block in content:
                if block.get("Type") == 2 and block.get("Text"):
                    blocks.append({"type": "text", "text": block["Text"]})
            if not blocks:
                continue
            msg = {"role": "user", "content": blocks}
            if timestamp:
                msg["timestamp"] = timestamp
            msg["index"] = len(normalized_messages)
            normalized_messages.append(msg)

        elif role == "assistant":
            blocks = []
            for block in content:
                if block.get("Type") == 2 and block.get("Text"):
                    blocks.append({"type": "text", "text": block["Text"]})
                elif block.get("Type") == 5:
                    tool_name = block.get("ToolName", "unknown")
                    input_summary = summarize_tool_input(tool_name, block.get("ToolInput"))
                    output = tool_results_map.get(block.get("ID"))
                    tc = {"type": "tool_call", "name": tool_name}
                    if input_summary is not None:
                        tc["input"] = input_summary
                    if output is not None:
                        tc["output"] = output
                    if block.get("ID"):
                        tc["tool_call_id"] = block["ID"]
                    blocks.append(tc)
            if not blocks:
                continue
            msg = {"role": "assistant", "content": blocks}
            if timestamp:
                msg["timestamp"] = timestamp
            msg["index"] = len(normalized_messages)
            normalized_messages.append(msg)

    metadata = {
        "tool_name": "shelley",
        "total_messages": len(normalized_messages),
    }
    if conv.get("conversation_id"):
        metadata["session_id"] = conv["conversation_id"]
    if conv.get("slug"):
        metadata["slug"] = conv["slug"]
    if conv.get("model"):
        metadata["model"] = conv["model"]
    if conv.get("cwd"):
        metadata["working_directory"] = conv["cwd"]
    if conv.get("created_at"):
        metadata["start_time"] = conv["created_at"]
    if conv.get("updated_at"):
        metadata["end_time"] = conv["updated_at"]

    return {
        "messages": normalized_messages,
        "metadata": metadata,
    }


def export_jsonl(db, conv):
    """Export a conversation as JSONL lines to stdout."""
    header = {
        "type": "shelley_session",
        "version": 1,
        "conversation_id": conv["conversation_id"],
        "slug": conv["slug"],
        "model": conv["model"],
        "cwd": conv["cwd"],
        "created_at": conv["created_at"],
        "updated_at": conv["updated_at"],
    }
    print(json.dumps(header, ensure_ascii=False))

    messages_raw = get_messages(db, conv["conversation_id"])
    for seq_id, msg_type, llm_data_json, created_at in messages_raw:
        role = role_from_type(msg_type)
        if role is None:
            continue
        try:
            llm_data = json.loads(llm_data_json) if llm_data_json else {}
        except json.JSONDecodeError:
            continue
        content = llm_data.get("Content", [])
        if not content:
            continue
        record = {
            "type": "message",
            "role": role,
            "sequence_id": seq_id,
            "timestamp": created_at,
            "content": content,
        }
        print(json.dumps(record, ensure_ascii=False))


def upload_to_forem(db, conv, ingest_url):
    """Build normalized data and POST to a Forem ingest URL."""
    normalized = build_normalized(db, conv)
    body = json.dumps(normalized, ensure_ascii=False).encode("utf-8")

    print(f"Uploading {normalized['metadata']['total_messages']} messages "
          f"({len(body)} bytes) to {ingest_url}", file=sys.stderr)

    req = urllib.request.Request(
        ingest_url,
        data=body,
        method="PUT",
        headers={
            "Content-Type": "application/json",
        },
    )

    try:
        with urllib.request.urlopen(req) as resp:
            result = json.loads(resp.read())
            if result.get("success"):
                print(f"\n✓ Session uploaded successfully!", file=sys.stderr)
                print(f"  View: {result.get('url', 'N/A')}", file=sys.stderr)
                print(f"  Edit: {result.get('edit_url', 'N/A')}", file=sys.stderr)
                print(f"  Slug: {result.get('slug', 'N/A')}", file=sys.stderr)
                print(f"  Messages: {result.get('total_messages', 'N/A')}", file=sys.stderr)
            else:
                print(f"Upload response: {result}", file=sys.stderr)
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", errors="replace")
        print(f"Upload failed (HTTP {e.code}): {body}", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"Connection failed: {e.reason}", file=sys.stderr)
        sys.exit(1)


def list_conversations(db, limit=20):
    """List recent conversations."""
    cursor = db.execute(
        "SELECT conversation_id, slug, model, "
        "datetime(created_at, 'localtime') as created, "
        "datetime(updated_at, 'localtime') as updated "
        "FROM conversations "
        "WHERE archived = 0 "
        "ORDER BY updated_at DESC LIMIT ?",
        (limit,),
    )
    rows = cursor.fetchall()
    if not rows:
        print("No conversations found.", file=sys.stderr)
        return

    print(f"{'ID':<10} {'Slug':<40} {'Model':<25} {'Updated'}", file=sys.stderr)
    print("-" * 100, file=sys.stderr)
    for row in rows:
        cid, slug, model, created, updated = row
        slug = slug or "(unnamed)"
        model = model or "(unknown)"
        print(f"{cid:<10} {slug:<40} {model:<25} {updated}", file=sys.stderr)


def main():
    parser = argparse.ArgumentParser(
        description="Export Shelley conversations to JSONL for Forem, or upload directly."
    )
    parser.add_argument(
        "conversation",
        nargs="?",
        help="Conversation ID or slug to export (omit to list recent conversations)",
    )
    parser.add_argument(
        "--db",
        default=get_db_path(),
        help="Path to Shelley SQLite database",
    )
    parser.add_argument(
        "--upload",
        metavar="URL",
        help="Forem ingest URL to upload to directly (e.g., https://dev.to/agent_sessions/ingest/TOKEN)",
    )
    args = parser.parse_args()

    if not os.path.exists(args.db):
        print(f"Database not found: {args.db}", file=sys.stderr)
        sys.exit(1)

    db = sqlite3.connect(f"file:{args.db}?mode=ro", uri=True)

    if not args.conversation:
        list_conversations(db)
        sys.exit(0)

    conv = find_conversation(db, args.conversation)
    if not conv:
        print(f"Conversation not found: {args.conversation}", file=sys.stderr)
        sys.exit(1)

    if args.upload:
        upload_to_forem(db, conv, args.upload)
    else:
        export_jsonl(db, conv)

    db.close()


if __name__ == "__main__":
    main()
