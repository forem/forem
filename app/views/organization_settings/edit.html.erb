  document.getElementById('org-page-preview-btn').addEventListener('click', function() {
    var textarea = document.getElementById('org_page_markdown');
    if (textarea) {
      document.getElementById('org-page-preview-markdown').value = textarea.value;
      document.getElementById('org-page-preview-form').submit();
    }
  });
</script>

