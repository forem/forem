<div id="ghostify-user">
  <div class="flex flex-col gap-4">
    <p>Are you absolutely sure you want to ghostify <span class="js-user-name fw-bold"></span>?</p>
    <p class="color-accent-danger fw-bold">This action is irreversible. All of this user's articles and comments will be permanently moved to the Ghost account.</p>
    <%= form_for(:user, html: { method: :post, id: nil, class: "js-ghostify-form" }) do %>
      <button class="c-btn c-btn--primary c-btn--destructive">Yes, ghostify <span class="js-user-name"></span></button>
    <% end %>
  </div>
</div>
