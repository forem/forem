<div>
  <h2 class="crayons-subtitle-1 mb-4">Abuse reports</h2>
  <ul class="crayons-navigation crayons-navigation--horizontal mb-4">
    <li>
      <a href="<%= admin_reports_path(state: @feedback_type, status: "Open") %>" class="crayons-navigation__item <%= "crayons-navigation__item--current" if @status == "Open" %>">Open/Unresolved</a>
    </li>
    <li>
      <a href="<%= admin_reports_path(state: @feedback_type, status: "Resolved") %>" class="crayons-navigation__item <%= "crayons-navigation__item--current" if @status == "Resolved" %>">Resolved</a>
    </li>
    <li>
      <a href="<%= admin_reports_path(state: @feedback_type, status: "Invalid") %>" class="crayons-navigation__item <%= "crayons-navigation__item--current" if @status == "Invalid" %>">Invalid</a>
  </ul>

  <div id="vomitReactions" class="mt-2">
    <details class="crayons-card w-100 cursor-pointer" id="vomitReactionsDetails">
      <summary class="crayons-subtitle-2 p-5" id="vomitReactionsHeader">
        Flag Reactions
        <% if @status == "Open" %>
          (<%= @vomits_count %>)
        <% end %>
      </summary>
      <div id="vomitReactionsBodyContainer" aria-labelledby="vomitReactionsHeader" data-parent="#vomitReactions">
        <div class="crayons-card__body" id="vomitReactionsBody" style="overflow: scroll; max-height: 500px;">
          <div class="text-center p-4" id="vomitReactionsLoading">
            Loading flag reactions...
          </div>
        </div>
      </div>
    </details>
  </div>
</div>

<script>
  (function() {
    const vomitDetails = document.getElementById('vomitReactionsDetails');
    const vomitBody = document.getElementById('vomitReactionsBody');
    let vomitLoaded = false;

    if (vomitDetails) {
      vomitDetails.addEventListener('toggle', function() {
        if (vomitDetails.open && !vomitLoaded) {
          const status = "<%= @status %>";
          fetch(`<%= flag_reactions_admin_reports_path %>?status=${status}`)
            .then(response => response.text())
            .then(html => {
              vomitBody.innerHTML = html;
              vomitLoaded = true;
            })
            .catch(error => {
              console.error('Error loading flag reactions:', error);
              const loadingElement = document.getElementById('vomitReactionsLoading');
              if (loadingElement) {
                loadingElement.innerText = 'Failed to load flag reactions.';
              }
            });
        }
      });
    }
  })();
</script>
