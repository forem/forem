<h1 class="crayons-title mb-3">Podcasts</h1>

<%= search_form_for(@q, url: admin_podcasts_path, class: "inline-flex") do |f| %>
  <%= f.search_field(:title_cont, aria: { label: "Search" }, class: "crayons-textfield", autocomplete: "off") %>
  <%= f.submit "Search", class: "crayons-btn ml-2" %>
<% end %>

<%= paginate @podcasts %>

<table class="crayons-table" width="100%">
  <thead>
    <tr>
      <th scope="col"><%= sort_link(@q, :id, { aria: { label: "Sort by ID" } }) %></th>
      <th scope="col"><%= sort_link(@q, :title, { aria: { label: "Sort by Title" } }) %></th>
      <th scope="col">Feed URL</th>
      <th scope="col">Eps</th>
      <th scope="col"><%= sort_link(@q, :reachable, { aria: { label: "Sort by Reachable" } }) %></th>
      <th scope="col"><%= sort_link(@q, :published, { aria: { label: "Sort by Published" } }) %></th>
      <th scope="col">Status Notice</th>
      <th scope="col">Owners</th>
    </tr>
  </thead>
  <tbody class="crayons-card">
    <% @podcasts.each do |podcast| %>
      <tr>
        <td class="whitespace-nowrap"><%= podcast.id %></td>
        <td><%= link_to podcast.title, edit_admin_podcast_path(podcast) %></td>
        <td><%= link_to podcast.feed_url, podcast.feed_url %></td>
        <td><%= podcast.episodes_count %></td>
        <td><%= podcast.reachable %></td>
        <td><%= podcast.published %></td>
        <td><%= podcast.status_notice %></td>
        <td>
          <% podcast.owners.select(:username).each do |user| %>
+            <p><%= link_to "@#{user.username}", user_url(user), target: "_blank", rel: :noopener %></p>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @podcasts %>
