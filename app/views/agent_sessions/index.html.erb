<% content_for :title, "Agent Sessions" %>

<div class="agent-session-index-page">
  <header class="agent-session-page-header">
    <div class="agent-session-index-header">
      <h1>Agent Sessions</h1>
      <div class="agent-session-header-actions">
        <button type="button" id="generate-ingest-link-btn" class="crayons-btn crayons-btn--secondary">Generate Upload Link</button>
        <%= link_to "Upload New Session", new_agent_session_path, class: "crayons-btn" %>
      </div>
    </div>

    <div id="ingest-link-result" class="agent-session-ingest-link" style="display:none">
      <p><strong>Upload link generated!</strong> Give this URL to Shelley or use it with <code>shelley-export</code>:</p>
      <div class="agent-session-ingest-link-row">
        <code id="ingest-link-url" class="agent-session-ingest-url"></code>
        <button type="button" id="copy-ingest-link-btn" class="crayons-btn crayons-btn--s">Copy</button>
      </div>
      <p class="agent-session-ingest-hint">This link is single-use and expires once a session is uploaded to it.</p>
    </div>
  </header>

  <% if @agent_sessions.any? %>
    <div class="agent-session-list">
      <% @agent_sessions.each do |session| %>
        <div class="agent-session-list-item">
          <div class="agent-session-list-item-main">
            <div class="agent-session-list-item-header">
              <%= agent_session_tool_icon(session.tool_name, show_label: false) %>
              <%= link_to session.title, edit_agent_session_path(session), class: "agent-session-list-item-title" %>
            </div>
            <div class="agent-session-list-item-meta">
              <span><%= session.curated_count %> / <%= session.total_messages %> messages included</span>
              <% if session.slices.any? %>
                <span><%= session.slices.size %> <%= "slice".pluralize(session.slices.size) %></span>
              <% end %>
              <span>Updated <%= time_ago_in_words(session.updated_at) %> ago</span>
            </div>
          </div>
          <div class="agent-session-list-item-actions">
            <code class="agent-session-embed-snippet"><%= "{" + "% agent_session #{session.id} %" + "}" %></code>
            <%= link_to "Curate", edit_agent_session_path(session), class: "crayons-btn crayons-btn--s crayons-btn--secondary" %>
            <%= link_to "View", agent_session_path(session), class: "crayons-btn crayons-btn--s crayons-btn--ghost" %>
            <%= button_to "Delete", agent_session_path(session), method: :delete, class: "crayons-btn crayons-btn--s crayons-btn--ghost crayons-btn--danger", data: { confirm: "Delete this session?" } %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="agent-session-empty-state">
      <p>No agent sessions yet.</p>
      <p>Upload a coding agent session to embed it in your posts.</p>
      <%= link_to "Upload Your First Session", new_agent_session_path, class: "crayons-btn" %>
    </div>
  <% end %>
</div>

<script>
(function() {
  var generateBtn = document.getElementById('generate-ingest-link-btn');
  var resultDiv = document.getElementById('ingest-link-result');
  var urlCode = document.getElementById('ingest-link-url');
  var copyBtn = document.getElementById('copy-ingest-link-btn');

  if (!generateBtn) return;

  generateBtn.addEventListener('click', function() {
    generateBtn.disabled = true;
    generateBtn.textContent = 'Generating...';

    var csrfToken = document.querySelector("meta[name='csrf-token']");
    fetch('<%= generate_ingest_link_agent_sessions_path %>', {
      method: 'POST',
      headers: {
        'X-CSRF-Token': csrfToken ? csrfToken.getAttribute('content') : '',
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      credentials: 'same-origin',
    }).then(function(resp) {
      return resp.json();
    }).then(function(data) {
      if (data.success && data.ingest_url) {
        urlCode.textContent = data.ingest_url;
        resultDiv.style.display = 'block';
        generateBtn.textContent = 'Generate Another Link';
        generateBtn.disabled = false;
      } else {
        alert('Error: ' + (data.error || 'Unknown error'));
        generateBtn.textContent = 'Generate Upload Link';
        generateBtn.disabled = false;
      }
    }).catch(function(err) {
      alert('Error: ' + err.message);
      generateBtn.textContent = 'Generate Upload Link';
      generateBtn.disabled = false;
    });
  });

  copyBtn.addEventListener('click', function() {
    navigator.clipboard.writeText(urlCode.textContent).then(function() {
      copyBtn.textContent = 'Copied!';
      setTimeout(function() { copyBtn.textContent = 'Copy'; }, 2000);
    });
  });
})();
</script>
