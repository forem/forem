<%= javascript_include_tag "calendarRangeSelect", defer: true %>
<main id="main-content" class="crayons-layout crayons-layout--header-inside">
  <header class="crayons-page-header flex items-center justify-between flex-wrap gap-3">
    <h1 class="crayons-title">Calendar</h1>

    <%= form_with url: calendar_path, method: :get, class: "calendar__range-picker flex items-end gap-2" do |f| %>
      <% if params[:type_of].present? %>
        <%= hidden_field_tag :type_of, params[:type_of] %>
      <% end %>
      <div>
        <label class="crayons-field__label fs-s" for="calendar-start">From</label>
        <%= date_field_tag :start, @range_start.iso8601, id: "calendar-start", class: "crayons-textfield" %>
      </div>
      <div>
        <label class="crayons-field__label fs-s" for="calendar-end">To</label>
        <%= date_field_tag :end, @range_end.iso8601, id: "calendar-end", class: "crayons-textfield" %>
      </div>
      <%= f.submit "Apply", class: "crayons-btn crayons-btn--secondary" %>
    <% end %>
  </header>

  <div class="calendar__layout px-3 m:px-0 pb-7">
    <aside class="calendar__sidebar">
      <%= render "calendar_widget" %>
    </aside>

    <section class="calendar__agenda">
      <h2 class="crayons-subtitle-2 mb-3"><%= calendar_range_header(@range_start, @range_end) %></h2>

      <% if @events_by_day.any? %>
        <% @events_by_day.each do |day, events| %>
          <h3 class="crayons-subtitle-3 color-base-60 mb-2 mt-4">
            <%= day == Time.zone.today ? "Today" : day.strftime("%a, %b %-d") %>
          </h3>
          <% events.each do |event| %>
            <%= render "event_row", event: event %>
          <% end %>
        <% end %>
        <%= render "pagination" %>
      <% else %>
        <div class="p-9 align-center crayons-card">
          <p class="text-center color-base-60 py-8">No events in this range. Try another month!</p>
        </div>
      <% end %>
    </section>
  </div>
</main>
