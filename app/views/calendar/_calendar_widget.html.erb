<%
  prev_month = @display_month - 1.month
  next_month = @display_month + 1.month
  grid_start = @grid_start
  grid_end = @grid_end
  today = Time.zone.today
%>
<div class="crayons-card p-4">
  <div class="flex items-center justify-between mb-3">
    <%= link_to "‹", calendar_path(month: prev_month.strftime("%Y-%m"), start: params[:start].presence, end: params[:end].presence, type_of: params[:type_of].presence), class: "calendar__nav-btn", "aria-label": t("views.calendar.nav.previous_month") %>
    <span class="fw-bold"><%= l(@display_month, format: "%B %Y") %></span>
    <%= link_to "›", calendar_path(month: next_month.strftime("%Y-%m"), start: params[:start].presence, end: params[:end].presence, type_of: params[:type_of].presence), class: "calendar__nav-btn", "aria-label": t("views.calendar.nav.next_month") %>
  </div>

  <div class="grid grid-cols-7 gap-1 align-center fs-s color-base-50 mb-1">
    <% t("views.calendar.weekdays").each do |label| %>
      <span class="text-center"><%= label %></span>
    <% end %>
  </div>

  <div class="grid grid-cols-7 gap-1" data-calendar-grid data-type-of="<%= params[:type_of] %>">
    <% (grid_start..grid_end).each do |day| %>
      <%
        classes = ["calendar__day", "text-center", "p-1"]
        classes << "color-base-30" unless day.month == @display_month.month
        classes << "calendar__day--has-event" if @event_day_set.include?(day)
        classes << "calendar__day--selected" if params[:start].present? && day >= @range_start && day <= @range_end
        classes << "calendar__day--today" if day == today
      %>
      <%= link_to day.day,
            calendar_path(start: day.iso8601, end: day.iso8601, type_of: params[:type_of].presence),
            class: classes.join(" "),
            data: { calendar_day: day.iso8601 } %>
    <% end %>
  </div>

  <p class="fs-s color-base-50 mt-3 mb-2"><%= t("views.calendar.hint") %></p>

  <ul class="calendar__legend list-none p-0 m-0 flex flex-wrap gap-3 fs-s color-base-60">
    <li class="flex items-center gap-1">
      <span class="calendar__legend-swatch calendar__legend-swatch--range" aria-hidden="true"></span><%= t("views.calendar.legend.selected") %>
    </li>
    <li class="flex items-center gap-1">
      <span class="calendar__legend-swatch calendar__legend-swatch--today" aria-hidden="true"></span><%= t("views.calendar.legend.today") %>
    </li>
    <li class="flex items-center gap-1">
      <span class="calendar__legend-dot" aria-hidden="true"></span><%= t("views.calendar.legend.has_events") %>
    </li>
  </ul>
</div>
