<% unless internal_navigation? || user_signed_in? %>
  <script type="application/ld+json">
    <%= @organization_json_ld.to_json.html_safe %>
  </script>
<% end %>
<style>
  :root {
    --profile-brand-color: <%= Color::CompareHex.new([user_colors(@user)[:bg], user_colors(@user)[:text]]).brightness(0.88) %>;
  }
<% if @cover_image_url.present? %>
  /* === COVER IMAGE MODE === */
  .org-header-cover {
    background-image: url('<%= optimized_image_url(@cover_image_url, width: 1000, random_fallback: false) %>');
    background-size: cover;
    background-position: center;
    aspect-ratio: 3 / 1;
  }
  @media (min-width: 768px) {
    .org-header-cover {
      aspect-ratio: 8 / 1;
    }
  }
<% else %>
  /* === COMPACT MODE (brand color bar) === */
  .org-header-cover {
    background: var(--profile-brand-color);
    height: 4px;
  }
<% end %>
  .org-header-main {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--su-3);
    padding: var(--su-4);
  }
  .org-header-logo {
    width: 56px;
    height: 56px;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.1);
    background-color: var(--card-bg);
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .org-header-logo {
      width: 80px;
      height: 80px;
    }
  }
  .org-header-logo img {
    border-radius: var(--radius);
    object-fit: cover;
    width: 100%;
    height: 100%;
  }
  .org-header-text {
    flex: 1;
    min-width: 0;
  }
  .org-header-text h1 {
    font-size: var(--fs-2xl);
    line-height: 1.2;
  }
  .org-header-actions {
    flex-shrink: 0;
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--su-1);
    max-width: 100%;
  }
  @media (min-width: 768px) {
    .org-header-actions {
      width: auto;
    }
  }
  .org-header-brand-line {
    height: 3px;
    background: var(--profile-brand-color);
  }
</style>

<div class="org-header-cover"></div>
<div class="org-header-brand-line"></div>
<div class="crayons-layout crayons-layout--limited-l">
  <%# Primary row: avatar + name/tagline + actions - same layout in both modes %>
  <div class="org-header-main">
    <span class="org-header-logo">
      <img src="<%= @user.profile_image_url_for(length: 320) %>" alt="<%= @user.name %> logo" title="<%= t("views.organizations.logo", org: @user.name) %>">
    </span>

    <div class="org-header-text">
      <h1 class="crayons-title fw-heavy">
        <%= sanitize @user.name %>
        <% if @organization.verified? %>
          <span class="screen-reader-only"><%= t("views.organizations.verified_badge") %></span>
          <%= crayons_icon_tag("verified", aria_hidden: true, style: "color: #3b82f6; margin-left: var(--su-1);", aria_title: t("views.organizations.verified_badge")) %>
        <% end %>
      </h1>
      <% if @user.tag_line.present? %>
        <p class="fs-base color-base-70 mt-1"><%= sanitize @user.tag_line %></p>
      <% end %>
    </div>

    <div class="org-header-actions flex items-center">
      <% if @organization.header_cta? %>
        <% if @organization.header_cta_dropdown? %>
          <div class="header-cta-dropdown relative">
            <button id="header-cta-toggle"
                    class="crayons-btn crayons-btn--outlined whitespace-nowrap mr-2"
                    aria-expanded="false"
                    aria-controls="header-cta-menu">
              <%= sanitize @organization.header_cta["text"] %>
              <%= crayons_icon_tag("chevron-down", class: "ml-1", title: t("views.organizations.header_cta.expand")) %>
            </button>
            <div id="header-cta-menu" class="crayons-dropdown p-4 right-0 top-100 mt-1" style="min-width: 280px; display: none;">
              <div class="grid gap-2">
                <% @organization.header_cta["links"].each do |link| %>
                  <a href="<%= link["url"] %>" target="_blank" rel="noopener noreferrer"
                     class="crayons-link crayons-link--block flex items-center gap-3 p-2 radius-default">
                    <% if link["logo_url"].present? %>
                      <img src="<%= link["logo_url"] %>" alt="" class="shrink-0" style="width: 32px; height: 32px; object-fit: contain;" loading="lazy" />
                    <% else %>
                      <%= crayons_icon_tag("external-link", class: "shrink-0 color-base-60") %>
                    <% end %>
                    <span class="fw-medium"><%= sanitize link["text"] %></span>
                  </a>
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <a href="<%= @organization.header_cta["url"] %>" target="_blank" rel="noopener noreferrer"
             class="crayons-btn crayons-btn--outlined whitespace-nowrap mr-2">
            <%= sanitize @organization.header_cta["text"] %>
          </a>
        <% end %>
      <% end %>
      <button
        id="user-follow-butt"
        class="crayons-btn whitespace-nowrap follow-action-button"
        data-info='<%= DataInfo.to_json(object: @user) %>'>
        <%= t("views.organizations.follow") %>
      </button>
      <style id="org-buttons-style">
        #org-settings-btn, #org-admin-btn { display: none !important; }
      </style>
      <script>
        try {
          var userStr = localStorage.getItem('current_user');
          if (userStr) {
            var currentUser = JSON.parse(userStr);
            var orgId = <%= @organization.id %>;
            var css = '';
            if (currentUser.admin_organization_ids && currentUser.admin_organization_ids.includes(orgId)) {
              css += '#org-settings-btn { display: inline-flex !important; } ';
            }
            if (currentUser.admin) {
              css += '#org-admin-btn { display: inline-flex !important; } ';
            }
            if (css) {
              document.getElementById('org-buttons-style').innerHTML += css;
            }
          }
        } catch (e) {
          // ignore
        }
      </script>
      <a href="/<%= @organization.slug %>/settings" id="org-settings-btn" class="crayons-btn crayons-btn--ghost-dimmed crayons-btn--icon ml-1" title="<%= t("views.organizations.settings_link") %>" data-org-id="<%= @organization.id %>">
        <%= crayons_icon_tag(:cog, title: t("views.organizations.settings_link")) %>
      </a>
      <a href="<%= admin_organization_path(@organization) %>" id="org-admin-btn" class="crayons-btn crayons-btn--ghost-dimmed crayons-btn--icon ml-1" title="<%= t("views.organizations.admin_link") %>" data-no-instant>
        <%= crayons_icon_tag("tools-line", title: t("views.organizations.admin_link")) %>
      </a>
      <div class="profile-dropdown ml-1 relative" data-organizationname="<%= @organization.name %>">
        <button id="organization-profile-dropdown" aria-expanded="false" aria-controls="organization-profile-dropdownmenu" aria-haspopup="true" class="crayons-btn crayons-btn--ghost-dimmed crayons-btn--icon">
          <%= crayons_icon_tag("overflow-horizontal", class: "dropdown-icon", title: t("views.organizations.dropdown")) %>
        </button>
        <div id="organization-profile-dropdownmenu" class="crayons-dropdown left-0 top-100 mt-1">
          <span class="report-abuse-link-wrapper" data-path="/report-abuse?url=<%= organization_url(@organization) %>"></span>
        </div>
      </div>
    </div>
  </div>

  <%# Secondary info: description + meta %>
  <% if @user.summary.present? || @user&.profile&.website_url.present? || @organization.location.present? %>
    <div class="px-4 m:px-0 pb-4" style="overflow-wrap: anywhere;">
      <% if @user.summary.present? %>
        <p class="fs-base color-base-90 mb-3"><%= sanitize @user.summary %></p>
      <% end %>

      <div class="fs-s color-base-60 flex flex-wrap items-center gap-y-1">
        <% if @user&.profile&.website_url.present? %>
          <a href="<%= @user&.profile&.website_url %>" target="_blank" rel="noopener noreferrer" class="mr-4 color-base-60 hover:color-base-90">
            <%= @user&.profile&.website_url.sub(%r{https?://}, '').chomp('/') %>
          </a>
        <% end %>
        <span class="flex items-center gap-1 mr-4">
          <% if @user.twitter_username.present? %>
            <a href="https://twitter.com/<%= @user.twitter_username %>" target="_blank" rel="noopener me" class="p-1 align-middle inline-block color-base-60 hover:color-base-90">
              <%= crayons_icon_tag(:twitter, title: t("views.organizations.social.twitter")) %>
            </a>
          <% end %>
          <% if @user.github_username.present? %>
            <a href="https://github.com/<%= @user.github_username %>" target="_blank" rel="noopener me" class="p-1 align-middle inline-block color-base-60 hover:color-base-90">
              <%= crayons_icon_tag(:github, title: t("views.organizations.social.github")) %>
            </a>
          <% end %>
          <% Organization::SOCIAL_LINK_PLATFORMS.each do |platform| %>
            <% url = @organization.social_link(platform) %>
            <% if url.present? %>
              <a href="<%= url %>" target="_blank" rel="noopener noreferrer" class="p-1 align-middle inline-block color-base-60 hover:color-base-90">
                <%= crayons_icon_tag(platform, title: t("views.organizations.social.#{platform}")) %>
              </a>
            <% end %>
          <% end %>
        </span>
        <% if @organization.location.present? %>
          <span class="flex items-center mr-4">
            <%= crayons_icon_tag(:location, class: "mr-1 shrink-0", title: t("views.organizations.location.icon")) %>
            <%= sanitize @organization.location %>
          </span>
        <% end %>
        <span class="flex items-center mr-4">
          <%= crayons_icon_tag(:cake, class: "mr-1 shrink-0", title: t("views.organizations.joined.icon")) %>
          <%= t("views.organizations.joined.text_html", date: local_date(@user.created_at)) %>
        </span>
        <% if @organization.email.present? %>
          <span class="flex items-center mr-4">
            <a href="mailto:<%= sanitize @organization.email %>" class="color-base-60 hover:color-base-90">
              <%= sanitize @organization.email %>
            </a>
          </span>
        <% end %>
        <% if @organization.company_size.present? %>
          <span class="mr-4"><%= t("views.organizations.size") %>: <%= @organization.company_size %></span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<%= javascript_include_tag "organizationDropdown",
                           defer: true %>
