<% if policy(Article).create? %>
<div class="crayons-card crayons-card--content-rows" id="rss">
  <div class="grid gap-4">
    <h2 class="crayons-subtitle-1">
      <%= t("views.settings.extensions.rss.heading", community: community_name) %>
    </h2>
    <p>
      We have moved RSS feed configuration to a new dedicated dashboard! You can now manage multiple feeds, set fallback organizations and users, and monitor import status.
    </p>
    <%= link_to "Go to RSS Feed Dashboard", rss_feeds_path, class: "crayons-btn crayons-btn--secondary w-max" %>
  </div>
</div>
<% end %>
