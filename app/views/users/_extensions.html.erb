<div class="crayons-card crayons-card--content-rows mb-6" id="rss-feeds">
  <header>
    <h2 class="mb-2">RSS Feeds</h2>
    <p>Manage your RSS feed imports from your dashboard.</p>
  </header>
  <div>
    <%= link_to "Manage my RSS feeds", "/dashboard/feed_imports", class: "crayons-btn crayons-btn--secondary block w-100 m:w-auto mt-4" %>
  </div>
</div>

<%= render partial: "content_preferences" if current_user.base_subscriber? %>

<%= render partial: "response_templates" %>

<%= render partial: "users/integrations_github_repositories", locals: { show_integration: @github_repositories_show } %>

<%= render partial: "api_keys" %>
