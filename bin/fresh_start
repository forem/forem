#!/usr/bin/env bash

# Exit immediately if a command exits with a non-zero status.
set -e

echo "🧹 Cleaning up /public cruft..."
# Remove built assets, uploads, and pipeline artifacts
rm -rf public/uploads/*
rm -rf public/assets/*
rm -rf public/packs/*
rm -rf public/packs-test/*
rm -rf public/builds/*

echo "🧹 Cleaning up /tmp cruft..."
# Clear standard Rails tmp (cache, pids, sockets)
bin/rails tmp:clear
bin/rails log:clear

# Strip out manual debugging files, random dumps, and testing artifacts
rm -rf tmp/capybara
rm -f tmp/*.rb
rm -f tmp/*.txt
rm -f tmp/*.json

echo "🌱 Truncating database and re-seeding..."
# db:seed:replant will truncate all tables (bypassing migrations) and load db/seeds.rb
bin/rails db:seed:replant

echo "✅ Fresh start complete! You're ready to go."
